<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Autoceny — Login</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
html{font-size:16px;-webkit-font-smoothing:antialiased}
body{
  font-family:'DM Sans',sans-serif;
  background:#F0FAF6;
  min-height:100vh;
  display:flex;flex-direction:column;
}

/* ── Nav ── */
.nav{
  height:56px;display:flex;align-items:center;padding:0 32px;
  background:#1A3F3A;
}
.nav__logo{display:flex;align-items:center;gap:8px}
.nav__badge{
  width:28px;height:28px;background:#234F49;border-radius:7px;
  display:grid;place-items:center;
}
.nav__badge svg{width:16px;height:16px;fill:#4BBFAE}
.nav__name{font:600 16px/1 'DM Sans',sans-serif;color:#fff}

/* ── Page ── */
.page{
  flex:1;display:flex;align-items:center;justify-content:center;
  padding:40px 24px;
}

/* ── Card ── */
.card{
  width:100%;max-width:440px;
  background:#fff;
  border-radius:20px;
  box-shadow:0 2px 24px rgba(26,63,58,0.06);
  overflow:hidden;
  transition:box-shadow .3s ease;
}

/* ── Toggle ── */
.toggle{
  padding:6px;margin:20px 20px 0;
  background:#EDEEED;
  border-radius:14px;
  display:flex;gap:4px;
}
.toggle__btn{
  flex:1;
  padding:12px 0;
  border:none;
  border-radius:11px;
  background:transparent;
  color:#656965;
  font:500 14px/1 'DM Sans',sans-serif;
  cursor:pointer;
  transition:all .25s ease;
  display:flex;align-items:center;justify-content:center;gap:8px;
}
.toggle__btn svg{
  width:18px;height:18px;
  stroke:currentColor;fill:none;stroke-width:1.5;
  transition:stroke .25s;
}
.toggle__btn--active{
  background:#fff;
  color:#1A3F3A;
  font-weight:600;
  box-shadow:0 1px 4px rgba(0,0,0,0.06);
}

/* Workshop active state — subtle teal tint */
.card--workshop .toggle__btn--active{
  background:#F0FAF6;
  color:#1A3F3A;
}

/* ── Card accent bar ── */
.card__accent{
  height:3px;
  background:#4BBFAE;
  margin:0 20px;
  border-radius:0 0 3px 3px;
  transition:background .3s ease;
}
.card--workshop .card__accent{
  background:#3BA99C;
}

/* ── Card body ── */
.card__body{
  padding:28px 32px 32px;
}

/* Logo */
.card__logo{
  width:52px;height:52px;
  background:#1A3F3A;border-radius:14px;
  display:grid;place-items:center;
  margin:0 auto 20px;
  transition:background .3s;
}
.card--workshop .card__logo{
  background:#234F49;
}
.card__logo svg{width:28px;height:28px;fill:#4BBFAE}

/* Title */
.card__title{
  font:700 22px/1.3 'DM Sans',sans-serif;
  color:#252825;text-align:center;margin-bottom:6px;
}
.card__subtitle{
  font:400 14px/1.5 'DM Sans',sans-serif;
  color:#868A86;text-align:center;margin-bottom:28px;
  transition:color .3s;
}

/* ── Role indicator badge ── */
.card__role{
  display:flex;align-items:center;justify-content:center;gap:6px;
  margin-bottom:24px;
  padding:8px 16px;
  border-radius:999px;
  font:500 12px/1 'DM Sans',sans-serif;
  width:fit-content;
  margin-left:auto;margin-right:auto;
  transition:all .3s ease;
}
.card__role svg{
  width:14px;height:14px;stroke:currentColor;fill:none;stroke-width:1.5;
}
.card__role--driver{
  background:#E3F5EF;color:#2D8A7E;
}
.card__role--workshop{
  background:#FDF6E3;color:#8B6914;
}

/* ── Form ── */
.form__group{margin-bottom:18px}
.form__label{
  display:block;font:500 13px/1 'DM Sans',sans-serif;
  color:#252825;margin-bottom:6px;
}
.form__input{
  width:100%;height:48px;padding:0 16px;
  background:#EDEEED;
  border:1.5px solid transparent;
  border-radius:12px;
  font:400 15px/1 'DM Sans',sans-serif;
  color:#252825;
  transition:all .2s ease;
}
.form__input::placeholder{color:#A5A9A5}
.form__input:hover{border-color:#C2C5C2}
.form__input:focus{
  background:#fff;
  border-color:#4BBFAE;
  outline:none;
  box-shadow:0 0 0 3px rgba(75,191,174,0.15);
}

.form__forgot{
  display:block;text-align:right;margin-top:6px;
  font:500 13px/1 'DM Sans',sans-serif;
  color:#3BA99C;text-decoration:none;
}
.form__forgot:hover{color:#2D8A7E}

/* Captcha placeholder */
.form__captcha{
  margin:20px 0;padding:14px;
  background:#F5F5F3;border-radius:10px;
  display:flex;align-items:center;justify-content:center;gap:10px;
  font:400 13px/1 'DM Sans',sans-serif;color:#868A86;
}
.form__captcha-check{
  width:22px;height:22px;border:2px solid #C2C5C2;border-radius:4px;
}

/* ── Submit button ── */
.form__submit{
  width:100%;height:50px;
  border:none;border-radius:999px;
  font:600 15px/1 'DM Sans',sans-serif;
  cursor:pointer;
  transition:all .25s ease;
}
.form__submit--driver{
  background:#1A3F3A;color:#fff;
}
.form__submit--driver:hover{
  background:#112E2A;
  box-shadow:0 4px 14px rgba(26,63,58,0.2);
}
.form__submit--workshop{
  background:#3BA99C;color:#fff;
}
.form__submit--workshop:hover{
  background:#2D8A7E;
  box-shadow:0 4px 14px rgba(59,169,156,0.25);
}

/* ── Footer link ── */
.card__footer{
  text-align:center;margin-top:22px;
  font:400 14px/1.5 'DM Sans',sans-serif;
  color:#868A86;
}
.card__footer a{
  color:#3BA99C;font-weight:600;text-decoration:none;
}
.card__footer a:hover{color:#2D8A7E}

/* ── Transitions for content swap ── */
.fade-content{
  transition:opacity .2s ease,transform .2s ease;
}
.fade-content--hidden{
  opacity:0;transform:translateY(6px);position:absolute;pointer-events:none;
}
.fade-content--visible{
  opacity:1;transform:translateY(0);position:relative;pointer-events:auto;
}
</style>
</head>
<body>

<!-- Nav -->
<nav class="nav">
  <div class="nav__logo">
    <div class="nav__badge">
      <svg viewBox="0 0 24 24"><path d="M12 2L4 10l2.5 2L12 7l5.5 5L20 10z"/><circle cx="12" cy="11.5" r="1.5"/></svg>
    </div>
    <span class="nav__name">Autoceny</span>
  </div>
</nav>

<!-- Page -->
<div class="page">
  <div class="card" id="card">

    <!-- Toggle -->
    <div class="toggle">
      <button class="toggle__btn toggle__btn--active" id="btn-driver" onclick="switchTo('driver')">
        <svg viewBox="0 0 24 24"><path d="M7 17m-2 0a2 2 0 104 0 2 2 0 10-4 0M17 17m-2 0a2 2 0 104 0 2 2 0 10-4 0M5 17H3v-6l2-5h9l4 5h1a2 2 0 012 2v4h-2m-4 0H9"/><path d="M10 6l-1 5h6"/></svg>
        Kierowca
      </button>
      <button class="toggle__btn" id="btn-workshop" onclick="switchTo('workshop')">
        <svg viewBox="0 0 24 24"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg>
        Warsztat
      </button>
    </div>

    <!-- Accent bar -->
    <div class="card__accent"></div>

    <!-- Card body -->
    <div class="card__body">

      <!-- Logo -->
      <div class="card__logo">
        <svg viewBox="0 0 24 24"><path d="M12 2L4 10l2.5 2L12 7l5.5 5L20 10z"/><circle cx="12" cy="11.5" r="1.5"/></svg>
      </div>

      <!-- Title -->
      <div class="card__title">Witaj ponownie</div>
      <div class="card__subtitle" id="subtitle">Zaloguj się, aby zarządzać zleceniami</div>

      <!-- Role badge -->
      <div class="card__role card__role--driver" id="role-badge">
        <svg viewBox="0 0 24 24"><path d="M7 17m-2 0a2 2 0 104 0 2 2 0 10-4 0M17 17m-2 0a2 2 0 104 0 2 2 0 10-4 0M5 17H3v-6l2-5h9l4 5h1a2 2 0 012 2v4h-2m-4 0H9"/><path d="M10 6l-1 5h6"/></svg>
        <span id="role-text">Logujesz się jako kierowca</span>
      </div>

      <!-- Form -->
      <div>
        <div class="form__group">
          <label class="form__label">Email</label>
          <input class="form__input" type="email" placeholder="ty@przykład.pl">
        </div>
        <div class="form__group">
          <label class="form__label">Hasło</label>
          <input class="form__input" type="password" placeholder="Wpisz hasło">
          <a href="#" class="form__forgot">Nie pamiętasz hasła?</a>
        </div>

        <!-- Captcha placeholder -->
        <div class="form__captcha">
          <div class="form__captcha-check"></div>
          <span>Verify you are human</span>
        </div>

        <!-- Submit -->
        <button class="form__submit form__submit--driver" id="submit-btn">Zaloguj się</button>
      </div>

      <!-- Footer -->
      <div class="card__footer" id="footer">
        Nie masz konta? <a href="#" id="footer-link">Utwórz je</a>
      </div>

    </div>
  </div>
</div>

<script>
function switchTo(mode) {
  const card = document.getElementById('card');
  const btnDriver = document.getElementById('btn-driver');
  const btnWorkshop = document.getElementById('btn-workshop');
  const subtitle = document.getElementById('subtitle');
  const roleBadge = document.getElementById('role-badge');
  const roleText = document.getElementById('role-text');
  const submitBtn = document.getElementById('submit-btn');
  const footer = document.getElementById('footer');

  if (mode === 'driver') {
    card.className = 'card';
    btnDriver.classList.add('toggle__btn--active');
    btnWorkshop.classList.remove('toggle__btn--active');
    subtitle.textContent = 'Zaloguj się, aby zarządzać zleceniami';
    roleBadge.className = 'card__role card__role--driver';
    roleText.textContent = 'Logujesz się jako kierowca';
    roleBadge.querySelector('svg').innerHTML = '<path d="M7 17m-2 0a2 2 0 104 0 2 2 0 10-4 0M17 17m-2 0a2 2 0 104 0 2 2 0 10-4 0M5 17H3v-6l2-5h9l4 5h1a2 2 0 012 2v4h-2m-4 0H9"/><path d="M10 6l-1 5h6"/>';
    submitBtn.className = 'form__submit form__submit--driver';
    footer.innerHTML = 'Nie masz konta? <a href="#">Utwórz je</a>';
  } else {
    card.className = 'card card--workshop';
    btnWorkshop.classList.add('toggle__btn--active');
    btnDriver.classList.remove('toggle__btn--active');
    subtitle.textContent = 'Zaloguj się, aby otrzymywać zlecenia napraw';
    roleBadge.className = 'card__role card__role--workshop';
    roleText.textContent = 'Logujesz się jako warsztat';
    roleBadge.querySelector('svg').innerHTML = '<path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/>';
    submitBtn.className = 'form__submit form__submit--workshop';
    footer.innerHTML = 'Nie masz konta? <a href="#">Zarejestruj warsztat</a>';
  }
}
</script>

</body>
</html>