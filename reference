      <div>
        <button class="hero__cta">Stwórz zlecenie naprawy</button>
        <a class="hero__link" href="#">Jesteś warsztatem?</a>
      </div>
    </div>
    <div class="hero__vis">
      <div class="hero__card">
        <div class="hero__pin hero__pin--1"><svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/></svg></div>
        <div class="hero__pin hero__pin--2"><svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/></svg></div>
        <div class="hero__pin hero__pin--3"><svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/></svg></div>
        <div class="card__head">
          <span class="card__dot"></span><span class="card__dot"></span><span class="card__dot"></span>
          <span style="margin-left:4px">Nowe zlecenie</span>
        </div>
        <div class="card__field">
          <div class="card__icon"><svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/></svg></div>
          Audi A3 Sportback · 2019
        </div>
        <div class="card__field">
          <div class="card__icon"><svg viewBox="0 0 24 24"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg></div>
          Hamulce piszczą przy hamowaniu
        </div>
        <div class="card__slider">
          <div class="card__track"><div class="card__fill"></div><div class="card__thumb"></div></div>
          <div class="card__val">15 km</div>
        </div>
        <div class="card__btn">Wyślij zlecenie</div>
      </div>
    </div>
  </div>
  <div class="hero__scroll"><svg viewBox="0 0 24 24"><path d="M7 13l5 5 5-5M7 6l5 5 5-5"/></svg></div>
</section>

<!-- TRUST BAR -->
<section class="trust">
  <div class="trust__in">
    <div class="trust__item rv"><div class="trust__icon"><svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/></svg></div><div class="trust__val">120+</div><div class="trust__label">Warsztatów w sieci</div></div>
    <div class="trust__item rv rv-d1"><div class="trust__icon"><svg viewBox="0 0 24 24"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg></div><div class="trust__val">~30%</div><div class="trust__label">Średnie oszczędności</div></div>
    <div class="trust__item rv rv-d2"><div class="trust__icon"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg></div><div class="trust__val">&lt; 2h</div><div class="trust__label">Średni czas wyceny</div></div>
    <div class="trust__item rv rv-d3"><div class="trust__icon"><svg viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26"/></svg></div><div class="trust__val">4.8/5</div><div class="trust__label">Ocena użytkowników</div></div>
  </div>
</section>

<!-- FEATURE 1 -->
<section class="feat feat--a" id="how">
  <div class="feat__in">
    <div class="feat__txt rv">
      <div class="feat__over">Dla kierowców</div>
      <h2 class="feat__title">Opisz usterkę raz</h2>
      <p class="feat__desc">Podaj dane auta, opisz problem i ustaw promień szukania. Twoje zlecenie automatycznie trafi do pobliskich warsztatów.</p>
      <button class="feat__btn">Stwórz zlecenie naprawy</button>
    </div>
    <div class="feat__vis rv rv-d1">
      <div class="fcard">
        <div class="fcard__form">
          <div class="ff"><svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/></svg>Audi A3 Sportback · 2019</div>
          <div class="ff"><svg viewBox="0 0 24 24"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg>Hamulce piszczą przy hamowaniu...</div>
          <div class="fslider"><div class="fs-track"><div class="fs-fill"></div><div class="fs-thumb"></div></div><div class="fs-val">15 km</div></div>
          <div class="ff-btn">Wyślij zlecenie</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- FEATURE 2 (reversed) -->
<section class="feat feat--b feat--rev">
  <div class="feat__in">
    <div class="feat__txt rv">
      <div class="feat__over">Porównaj i wybierz</div>
      <h2 class="feat__title">Otrzymaj wyceny i&nbsp;wybierz</h2>
      <p class="feat__desc">Porównuj ceny, odległości i komentarze obok siebie. Wybierz najlepszą ofertę i skontaktuj się z warsztatem.</p>
      <button class="feat__btn">Stwórz zlecenie naprawy</button>
    </div>
    <div class="feat__vis rv rv-d1">
      <div class="fcard" style="padding:18px">
        <div class="fcard__head"><div class="fcard__title">Audi A3 · hamulce</div><span class="fcard__badge badge--green">Otwarte</span></div>
        <div class="fquote">
          <div class="fq-name">Auto Serwis Kowalski</div>
          <div class="fq-meta">2.4 km · Otrzymano dzisiaj</div>
          <div class="fq-price">520–680 <span>PLN</span></div>
          <div class="fq-acts"><button class="fq-btn fq-btn--pri">Zainteresowany</button><button class="fq-btn fq-btn--sec">Ignoruj</button></div>
        </div>
        <div class="fquote fquote--dim">
          <div class="fq-name">Quick Fix Garage</div>
          <div class="fq-meta">7.8 km · Otrzymano dzisiaj</div>
          <div class="fq-price">550–700 <span>PLN</span></div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- FEATURE 3 -->
<section class="feat feat--a">
  <div class="feat__in">
    <div class="feat__txt rv">
      <div class="feat__over">Dla warsztatów</div>
      <h2 class="feat__title">Analizuj i&nbsp;doprecyzuj</h2>
      <p class="feat__desc">Przejrzyj zlecenie, potwierdź zainteresowanie i zadaj dodatkowe pytania, zanim przygotujesz wycenę.</p>
      <button class="feat__btn">Dołącz jako warsztat</button>
    </div>
    <div class="feat__vis rv rv-d1">
      <div class="fcard" style="padding:18px">
        <div class="fcard__head"><div class="fcard__title">Audi A3 · hamulce</div><span class="fcard__badge badge--amber">Nowe zlecenie</span></div>
        <div class="fw-order">
          <div class="fw-order__desc">Hamulce piszczą przy hamowaniu...</div>
          <div class="fw-order__dist">2.4 km od Ciebie</div>
        </div>
        <button class="fw-accept">Przyjmij do przeglądu</button>
        <div class="fw-input"><div class="fw-input__field">Wpisz pytanie do kierowcy...</div></div>
      </div>
    </div>
  </div>
</section>

<!-- WHY -->
<section class="why">
  <div class="why__in">
    <h2 class="why__head rv">Dlaczego Autoceny?</h2>
    <div class="why__grid">
      <div>
        <div class="why__col-title">Dla kierowców</div>
        <div class="why__item rv"><div class="why__icon"><svg viewBox="0 0 24 24"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg></div><div><div class="why__item-title">Oszczędzaj</div><div class="why__item-desc">Porównuj realne wyceny zamiast zgadywać ceny.</div></div></div>
        <div class="why__item rv rv-d1"><div class="why__icon"><svg viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.12.96.36 1.9.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.91.34 1.85.58 2.81.7A2 2 0 0122 16.92z"/></svg></div><div><div class="why__item-title">Bez obdzwaniania</div><div class="why__item-desc">Jedno zlecenie trafia do każdego warsztatu w promieniu.</div></div></div>
        <div class="why__item rv rv-d2"><div class="why__icon"><svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg></div><div><div class="why__item-title">Łatwe porównanie</div><div class="why__item-desc">Ceny, odległości i opinie obok siebie.</div></div></div>
      </div>
      <div>
        <div class="why__col-title">Dla warsztatów</div>
        <div class="why__item rv"><div class="why__icon"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M16 12l-4-4-4 4M12 16V8"/></svg></div><div><div class="why__item-title">Klienci gotowi na naprawę</div><div class="why__item-desc">Każde zlecenie pochodzi od kierowcy gotowego naprawić auto.</div></div></div>
        <div class="why__item rv rv-d1"><div class="why__icon"><svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2v10z"/></svg></div><div><div class="why__item-title">Mniej przekazywania informacji</div><div class="why__item-desc">Zadawaj pytania i wyceniaj bezpośrednio w aplikacji.</div></div></div>
        <div class="why__item rv rv-d2"><div class="why__icon"><svg viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg></div><div><div class="why__item-title">Wygrywaj lokalnie</div><div class="why__item-desc">Konkuruj wartością w swojej okolicy.</div></div></div>
      </div>
    </div>
  </div>
</section>

<!-- PRICING -->
<section class="pricing" id="pricing">
  <div class="pricing__in">
    <h2 class="pricing__head rv">Cennik</h2>
    <p class="pricing__sub rv">Dla kierowców i warsztatów</p>
    <div class="pricing__tabs rv">
      <button class="pricing__tab pricing__tab--on"><svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>Kierowcy</button>
      <button class="pricing__tab"><svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/></svg>Warsztaty</button>
    </div>
    <div class="pricing__cards rv">
      <div class="pcard">
        <div class="pcard__plan">Darmowy plan</div>
        <div class="pcard__price">0 zł <span>/ miesiąc</span></div>
        <div class="pcard__desc">Wystarczy do sprawdzenia Autoceny.</div>
