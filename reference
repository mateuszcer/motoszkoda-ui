        <div class="pcard__limit"><span class="pcard__limit-l">Otwarte zlecenia</span><span class="pcard__limit-v">3</span></div>
        <div class="pcard__limit"><span class="pcard__limit-l">Zlecenia / dzień</span><span class="pcard__limit-v">1</span></div>
        <div class="pcard__limit"><span class="pcard__limit-l">Pytania / zlecenie</span><span class="pcard__limit-v">2</span></div>
        <button class="pcard__cta pcard__cta--sec">Zacznij za darmo</button>
        <div class="pcard__foot">Bez karty kredytowej.</div>
      </div>
      <div class="pcard pcard--feat">
        <div class="pcard__plan">Plan Premium</div>
        <div class="pcard__price">29 zł <span>/ miesiąc</span></div>
        <div class="pcard__desc">Pełny dostęp — bez limitów zleceń i pytań.</div>
        <ul class="pcard__features">
          <li class="pcard__feat"><svg class="pcard__check" viewBox="0 0 24 24"><path d="M20 6L9 17l-5-5"/></svg>Wszystko z darmowego planu</li>
          <li class="pcard__feat"><svg class="pcard__check" viewBox="0 0 24 24"><path d="M20 6L9 17l-5-5"/></svg>Bez limitu zleceń i pytań</li>
          <li class="pcard__feat"><svg class="pcard__check" viewBox="0 0 24 24"><path d="M20 6L9 17l-5-5"/></svg>Priorytetowe wyświetlanie</li>
        </ul>
        <button class="pcard__cta pcard__cta--pri">Wybierz Premium</button>
      </div>
    </div>
  </div>
</section>

<!-- BOTTOM CTA -->
<section class="bcta">
  <div class="bcta__in rv">
    <h2 class="bcta__title">Napraw auto mądrzej</h2>
    <p class="bcta__desc">Dołącz do kierowców, którzy oszczędzają czas i pieniądze dzięki Autoceny.</p>
    <button class="bcta__btn">Stwórz zlecenie naprawy</button>
  </div>
</section>

<!-- FOOTER -->
<footer class="foot">
  <div class="foot__in">
    <div class="foot__logo"><div class="foot__badge">AC</div><span class="foot__name">Autoceny</span></div>
    <div class="foot__links"><a class="foot__link">Jak to działa</a><a class="foot__link">Cennik</a><a class="foot__link">FAQ</a><a class="foot__link">Kontakt</a></div>
    <div class="foot__copy">© 2026 Autoceny</div>
  </div>
</footer>

<script>
const n=document.getElementById('nav');
new IntersectionObserver(([e])=>{n.classList.toggle('nav--clear',e.isIntersecting);n.classList.toggle('nav--solid',!e.isIntersecting)},{threshold:.7}).observe(document.querySelector('.hero'));
document.querySelectorAll('.rv').forEach(el=>new IntersectionObserver(([e])=>{if(e.isIntersecting)e.target.classList.add('vis')},{threshold:.12,rootMargin:'0px 0px -30px 0px'}).observe(el));
</script>
</body>
