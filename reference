<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Autoceny — Pixel Reference v3</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Josefin+Sans:wght@300;400;500;600&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700&display=swap" rel="stylesheet">
<style>
/*
 ╔══════════════════════════════════════════════════════════╗
 ║  AUTOCENY LANDING PAGE — PIXEL-PERFECT REFERENCE v3     ║
 ║                                                          ║
 ║  Font:  Josefin Sans (geometric sans, weight 600 hero)    ║
 ║  Green: #6ECFAB (cool mint, NOT warm sage)               ║
 ║  Dark:  #1B3533 (dark teal, NOT brown-green)             ║
 ║                                                          ║
 ║  This file IS the design spec. Match it exactly.         ║
 ╚══════════════════════════════════════════════════════════╝
*/

:root {
  --mint: #6ECFAB;
  --mint-light: #8DDBC0;
  --mint-dark: #4CB890;
  --mint-subtle: #EAF9F2;
  --teal-900: #0C1B19;
  --teal-800: #122623;
  --teal-700: #1B3533;
  --teal-600: #213F3C;
  --teal-500: #2D524E;
  --n900: #252825;
  --n700: #4D504D;
  --n600: #656965;
  --n500: #868A86;
  --n400: #A5A9A5;
  --n300: #C2C5C2;
  --n200: #DCDEDD;
  --n100: #EDEEED;
  --n75: #F2F3F2;
  --n50: #F5F5F3;
  --white: #FFFFFF;
  --font-h: 'Josefin Sans', sans-serif;
  --font-b: 'DM Sans', sans-serif;
  --section-pad: clamp(80px, 10vw, 140px);
  --max-w: 1140px;
}

*, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
html { font-size:16px; -webkit-font-smoothing:antialiased; scroll-behavior:smooth; }
body { font-family:var(--font-b); color:var(--n900); background:var(--n50); line-height:1.6; overflow-x:hidden; }
img { display:block; max-width:100%; }
a { text-decoration:none; color:inherit; }
button { font-family:var(--font-b); cursor:pointer; }

/* ══════════ NAV ══════════ */
.nav {
  position:fixed; top:0; left:0; right:0; z-index:100;
  height:64px; display:flex; align-items:center;
  padding:0 40px; transition:all .4s ease;
}
.nav--clear { background:transparent; }
.nav--solid { background:var(--teal-800); box-shadow:0 1px 0 rgba(0,0,0,.06); }
.nav__in { display:flex; align-items:center; justify-content:space-between; width:100%; max-width:var(--max-w); margin:0 auto; }
.nav__logo { display:flex; align-items:center; gap:10px; }
.nav__badge { width:30px; height:30px; background:var(--teal-600); border-radius:7px; display:grid; place-items:center; font:700 12px/1 var(--font-b); color:var(--mint-light); }
.nav__name { font:600 17px/1 var(--font-b); color:#fff; }
.nav__links { display:flex; gap:32px; }
.nav__link { font:500 14px/1 var(--font-b); color:rgba(255,255,255,.5); transition:color .2s; }
.nav__link:hover { color:rgba(255,255,255,.85); }
.nav__acts { display:flex; gap:10px; align-items:center; }

/* Nav buttons — ONE primary, ONE secondary. Not two primaries. */
.nav__btn-pri {
  height:36px; padding:0 18px; border-radius:999px; border:none;
  background:var(--mint); color:var(--teal-900);
  font:600 13px/1 var(--font-b);
  transition:all .2s;
}
.nav__btn-pri:hover { background:var(--mint-light); }
.nav__btn-sec {
  height:36px; padding:0 18px; border-radius:999px;
  background:transparent; border:1.5px solid rgba(255,255,255,.18);
  color:rgba(255,255,255,.6); font:500 13px/1 var(--font-b);
  transition:all .2s;
}
.nav__btn-sec:hover { border-color:rgba(255,255,255,.35); color:rgba(255,255,255,.85); }

/* ══════════ HERO ══════════ */
.hero {
  position:relative; min-height:100vh; background:var(--teal-700);
  display:flex; align-items:center; overflow:hidden;
}
.hero::before {
  content:''; position:absolute; top:-20%; right:-5%; width:60%; height:140%;
  background:radial-gradient(ellipse at center, rgba(110,207,171,.05) 0%, transparent 70%);
}
.hero__in {
  position:relative; z-index:1;
  display:grid; grid-template-columns:1fr 1fr; align-items:center; gap:60px;
  max-width:var(--max-w); margin:0 auto; padding:0 40px; width:100%;
}
.hero__text { padding-top:20px; }

/*
   THE HEADLINE.
   Josefin Sans. Weight 300. Color #6ECFAB.
   ALL ONE COLOR — no highlighting individual words.
   SHORT COPY — 4-5 words max.
*/
.hero__title {
  font-family:var(--font-h);
  font-weight:600;
  font-size:clamp(44px, 4.8vw, 66px);
  line-height:1.1;
  letter-spacing:-0.01em;
  color:var(--mint);
  margin-bottom:24px;
}

.hero__sub {
  font:400 16px/1.7 var(--font-b);
  color:rgba(255,255,255,.45);
  max-width:380px;
  margin-bottom:36px;
}

/* ONE button. Small. Quiet. Pill. White bg on dark. */
.hero__cta {
  display:inline-flex; align-items:center; justify-content:center;
  height:48px; padding:0 28px; border-radius:999px; border:none;
  background:var(--white); color:var(--teal-700);
  font:600 15px/1 var(--font-b);
  box-shadow:0 2px 12px rgba(0,0,0,.08);
  transition:all .25s ease;
}
.hero__cta:hover { transform:translateY(-2px); box-shadow:0 4px 20px rgba(0,0,0,.14); }

.hero__link {
  display:inline-block; margin-left:28px;
  font:500 14px/1 var(--font-b);
  color:rgba(255,255,255,.38);
  border-bottom:1px solid rgba(255,255,255,.18);
  padding-bottom:2px;
  transition:all .2s;
}
.hero__link:hover { color:rgba(255,255,255,.65); border-color:rgba(255,255,255,.4); }

/* Hero visual */
.hero__vis { display:flex; justify-content:center; align-items:center; position:relative; padding-top:20px; }

.hero__card {
  width:340px;
  background:rgba(255,255,255,.05);
  backdrop-filter:blur(12px);
  border:1px solid rgba(255,255,255,.07);
  border-radius:18px;
  padding:24px;
  position:relative;
}
.card__head { display:flex; align-items:center; gap:6px; margin-bottom:18px; font:500 12px/1 var(--font-b); color:rgba(255,255,255,.3); }
.card__dot { width:6px; height:6px; border-radius:50%; }
.card__dot:nth-child(1) { background:var(--mint); opacity:.6; }
.card__dot:nth-child(2) { background:var(--mint); opacity:.35; }
.card__dot:nth-child(3) { background:var(--mint); opacity:.15; }
.card__field {
  background:rgba(255,255,255,.04); border:1px solid rgba(255,255,255,.06);
  border-radius:9px; padding:12px 14px; margin-bottom:10px;
  display:flex; align-items:center; gap:9px;
  font:400 13px/1.3 var(--font-b); color:rgba(255,255,255,.6);
}
.card__icon {
  width:16px; height:16px; border-radius:4px; background:rgba(110,207,171,.15);
  display:grid; place-items:center; flex-shrink:0;
}
.card__icon svg { width:10px; height:10px; stroke:var(--mint); fill:none; stroke-width:2; }
.card__slider { display:flex; align-items:center; gap:10px; margin:16px 0 18px; }
.card__track { flex:1; height:3px; background:rgba(255,255,255,.08); border-radius:2px; position:relative; }
.card__fill { position:absolute; left:0; top:0; height:100%; width:40%; background:var(--mint); border-radius:2px; }
.card__thumb { position:absolute; left:40%; top:50%; transform:translate(-50%,-50%); width:12px; height:12px; background:var(--mint); border-radius:50%; border:2px solid var(--teal-700); }
.card__val { font:500 13px/1 var(--font-b); color:var(--mint); min-width:40px; text-align:right; }

/* Small, subdued submit button INSIDE the mockup */
.card__btn {
  display:inline-flex; height:32px; padding:0 14px; align-items:center;
  background:rgba(110,207,171,.15); color:var(--mint);
  border-radius:7px; font:600 12px/1 var(--font-b); border:none;
}

/* Floating pins — SMALL and SUBTLE */
.hero__pin {
  position:absolute; width:32px; height:32px;
  background:rgba(255,255,255,.04); backdrop-filter:blur(6px);
  border:1px solid rgba(255,255,255,.06); border-radius:8px;
  display:grid; place-items:center;
  animation:fl 7s ease-in-out infinite;
}
.hero__pin svg { width:14px; height:14px; stroke:rgba(255,255,255,.2); fill:none; stroke-width:1.5; }
.hero__pin--1 { top:15%; right:-24px; animation-delay:0s; }
.hero__pin--2 { bottom:25%; right:-18px; animation-delay:-2.5s; }
.hero__pin--3 { bottom:10%; left:-12px; animation-delay:-4.5s; }
@keyframes fl { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-6px)} }

.hero__scroll {
  position:absolute; bottom:28px; left:50%; transform:translateX(-50%); z-index:1;
}
.hero__scroll svg { width:18px; height:18px; stroke:rgba(255,255,255,.2); fill:none; stroke-width:2; animation:sb 2.5s ease-in-out infinite; }
@keyframes sb { 0%,100%{transform:translateY(0);opacity:.3} 50%{transform:translateY(5px);opacity:.6} }


/* ══════════ TRUST BAR ══════════ */
.trust {
  background:var(--teal-900); padding:44px 40px;
}
.trust__in {
  max-width:var(--max-w); margin:0 auto;
  display:grid; grid-template-columns:repeat(4,1fr); gap:32px;
}
.trust__item { text-align:center; }
.trust__icon {
  width:36px; height:36px; margin:0 auto 12px;
  background:rgba(110,207,171,.08); border-radius:9px;
  display:grid; place-items:center;
}
.trust__icon svg { width:18px; height:18px; stroke:var(--mint); fill:none; stroke-width:1.5; }
.trust__val { font:700 20px/1.2 var(--font-b); color:#fff; margin-bottom:4px; }
.trust__label { font:500 11px/1.3 var(--font-b); color:rgba(255,255,255,.35); text-transform:uppercase; letter-spacing:.08em; }


/* ══════════ FEATURE SECTIONS ══════════ */
.feat { padding:var(--section-pad) 40px; }
.feat--a { background:var(--n50); }
.feat--b { background:var(--n75); }
.feat__in {
  max-width:var(--max-w); margin:0 auto;
  display:grid; grid-template-columns:1fr 1fr; gap:72px; align-items:center;
}
.feat--rev .feat__in { direction:rtl; }
.feat--rev .feat__txt, .feat--rev .feat__vis { direction:ltr; }

.feat__over {
  font:600 11px/1.3 var(--font-b); color:var(--mint-dark);
  text-transform:uppercase; letter-spacing:.1em; margin-bottom:14px;
}
.feat__title {
  font-family:var(--font-h); font-weight:500; /* Medium for section titles */
  font-size:clamp(28px, 3.2vw, 42px); line-height:1.15; letter-spacing:-0.005em;
  color:var(--n900); margin-bottom:18px;
}
.feat__desc {
  font:400 15px/1.7 var(--font-b); color:var(--n600);
  max-width:400px; margin-bottom:28px;
}
.feat__btn {
  height:44px; padding:0 24px; border-radius:999px; border:none;
  background:var(--teal-700); color:#fff;
  font:600 14px/1 var(--font-b);
  transition:all .25s ease;
}
.feat__btn:hover { background:var(--teal-600); transform:translateY(-1px); box-shadow:0 4px 14px rgba(27,53,51,.18); }

/* Feature mockup cards */
.feat__vis { display:flex; justify-content:center; }
.fcard {
  background:var(--white); border-radius:18px; padding:22px;
  width:100%; max-width:380px;
  box-shadow:0 2px 20px rgba(27,53,51,.05);
}
.fcard__head {
  display:flex; align-items:center; justify-content:space-between;
  margin-bottom:16px; padding-bottom:14px; border-bottom:1px solid var(--n100);
}
.fcard__title { font:600 14px/1.3 var(--font-b); color:var(--n900); }
.fcard__badge {
  display:inline-flex; height:22px; padding:0 9px; align-items:center;
  border-radius:999px; font:600 10px/1 var(--font-b);
}
.badge--green { background:var(--mint-subtle); color:#2D7A56; }
.badge--amber { background:#FDF6E3; color:#8B6914; }

.fcard__form {
  background:var(--n75); border-radius:12px; padding:16px;
}
.ff {
  background:var(--white); border:1.5px solid var(--n200); border-radius:9px;
  padding:10px 12px; margin-bottom:8px;
  display:flex; align-items:center; gap:8px;
  font:400 13px/1.3 var(--font-b); color:var(--n700);
}
.ff svg { width:14px; height:14px; stroke:var(--n400); fill:none; stroke-width:2; flex-shrink:0; }
.fslider { display:flex; align-items:center; gap:8px; margin:12px 0 14px; }
.fs-track { flex:1; height:3px; background:var(--n200); border-radius:2px; position:relative; }
.fs-fill { position:absolute; left:0; top:0; height:100%; width:40%; background:var(--mint-dark); border-radius:2px; }
.fs-thumb { position:absolute; left:40%; top:50%; transform:translate(-50%,-50%); width:14px; height:14px; background:#fff; border:2px solid var(--mint-dark); border-radius:50%; }
.fs-val { font:600 13px/1 var(--font-b); color:var(--teal-600); min-width:42px; text-align:right; }
.ff-btn {
  display:inline-flex; height:32px; padding:0 14px; align-items:center;
  background:var(--teal-700); color:#fff;
  border-radius:7px; font:600 12px/1 var(--font-b);
}

/* Quote card */
.fquote {
  background:var(--n75); border-radius:12px; padding:16px;
  margin-bottom:10px; border-left:3px solid var(--mint);
}
.fquote--dim { opacity:.55; border-left-color:var(--n300); }
.fq-name { font:600 13px/1.3 var(--font-b); color:var(--n900); }
.fq-meta { font:400 11px/1.3 var(--font-b); color:var(--n500); margin:2px 0 8px; }
.fq-price { font:700 22px/1.2 var(--font-b); color:var(--n900); letter-spacing:-.01em; }
.fq-price span { font:400 13px/1 var(--font-b); color:var(--n500); }
.fq-acts { display:flex; gap:6px; margin-top:10px; }
.fq-btn {
  height:28px; padding:0 12px; border-radius:999px;
  font:600 11px/1 var(--font-b); display:inline-flex; align-items:center;
  transition:all .15s;
}
.fq-btn--pri { background:var(--teal-700); color:#fff; border:none; }
.fq-btn--sec { background:transparent; color:var(--n600); border:1.5px solid var(--n200); }

/* Workshop card */
.fw-order {
  background:var(--n75); border-radius:10px; padding:14px; margin-bottom:10px;
}
.fw-order__desc { font:400 12px/1.5 var(--font-b); color:var(--n500); margin-bottom:4px; }
.fw-order__dist { font:400 11px/1.3 var(--font-b); color:var(--n400); }
.fw-accept {
  width:100%; height:34px; border-radius:999px; border:none;
  background:var(--teal-700); color:#fff;
  font:600 12px/1 var(--font-b);
  display:flex; align-items:center; justify-content:center;
}
.fw-input {
  margin-top:14px; padding-top:14px; border-top:1px solid var(--n100);
}
.fw-input__field {
  background:var(--n75); border-radius:8px; padding:10px 12px;
  font:400 12px/1.3 var(--font-b); color:var(--n500);
}


/* ══════════ WHY SECTION ══════════ */
.why { padding:var(--section-pad) 40px; background:var(--white); }
.why__in { max-width:var(--max-w); margin:0 auto; }
.why__head {
  font-family:var(--font-h); font-weight:500;
  font-size:clamp(28px, 3.2vw, 42px); line-height:1.15;
  color:var(--n900); text-align:center; margin-bottom:56px;
}
.why__grid { display:grid; grid-template-columns:1fr 1fr; gap:56px 72px; }
.why__col-title {
  font:600 11px/1.3 var(--font-b); color:var(--mint-dark);
  text-transform:uppercase; letter-spacing:.08em;
  margin-bottom:28px; padding-bottom:14px; border-bottom:1.5px solid var(--n100);
}
.why__item { display:flex; gap:14px; margin-bottom:28px; }
.why__icon {
  width:40px; height:40px; background:var(--mint-subtle); border-radius:10px;
  display:grid; place-items:center; flex-shrink:0;
}
.why__icon svg { width:18px; height:18px; stroke:var(--mint-dark); fill:none; stroke-width:1.5; }
.why__item-title { font:600 15px/1.4 var(--font-b); color:var(--n900); margin-bottom:3px; }
.why__item-desc { font:400 13px/1.6 var(--font-b); color:var(--n600); }


/* ══════════ PRICING ══════════ */
.pricing { padding:var(--section-pad) 40px; background:var(--n50); }
.pricing__in { max-width:820px; margin:0 auto; }
.pricing__head {
  font-family:var(--font-h); font-weight:500;
  font-size:clamp(28px, 3.2vw, 42px); line-height:1.15;
  color:var(--n900); text-align:center; margin-bottom:6px;
}
.pricing__sub { font:400 15px/1.5 var(--font-b); color:var(--n600); text-align:center; margin-bottom:40px; }
.pricing__tabs { display:flex; justify-content:center; gap:8px; margin-bottom:36px; }
.pricing__tab {
  height:38px; padding:0 20px; border-radius:999px;
  font:500 13px/1 var(--font-b);
  display:inline-flex; align-items:center; gap:6px;
  transition:all .2s; border:1.5px solid var(--n200); background:transparent; color:var(--n600);
}
.pricing__tab svg { width:15px; height:15px; stroke:currentColor; fill:none; stroke-width:1.5; }
.pricing__tab--on { background:var(--teal-700); border-color:var(--teal-700); color:#fff; }
.pricing__cards { display:grid; grid-template-columns:1fr 1fr; gap:20px; }
.pcard {
  background:var(--white); border-radius:18px; padding:32px;
  box-shadow:0 1px 3px rgba(27,53,51,.03); display:flex; flex-direction:column;
}
.pcard--feat { box-shadow:0 4px 20px rgba(27,53,51,.07); position:relative; }
.pcard--feat::before { content:''; position:absolute; top:0; left:0; right:0; height:3px; background:var(--mint); border-radius:18px 18px 0 0; }
.pcard__plan { font:600 13px/1.3 var(--font-b); color:var(--n600); margin-bottom:6px; }
.pcard__price { font:700 36px/1.1 var(--font-b); color:var(--n900); letter-spacing:-.02em; margin-bottom:4px; }
.pcard__price span { font:400 15px/1 var(--font-b); color:var(--n500); }
.pcard__desc { font:400 13px/1.6 var(--font-b); color:var(--n600); margin-bottom:24px; padding-bottom:24px; border-bottom:1px solid var(--n100); }
.pcard__features { list-style:none; margin-bottom:28px; flex:1; }
.pcard__feat {
  display:flex; align-items:flex-start; gap:8px; margin-bottom:12px;
  font:400 13px/1.5 var(--font-b); color:var(--n700);
}
.pcard__check { width:16px; height:16px; stroke:var(--mint-dark); fill:none; stroke-width:2; flex-shrink:0; margin-top:1px; }
.pcard__limit {
  display:flex; justify-content:space-between; padding:8px 0;
  border-bottom:1px solid var(--n100); font:400 13px/1.4 var(--font-b);
}
.pcard__limit:last-of-type { border:none; }
.pcard__limit-l { color:var(--n600); }
.pcard__limit-v { font-weight:700; color:var(--n900); }
.pcard__cta {
  height:44px; width:100%; border-radius:999px;
  font:600 14px/1 var(--font-b); margin-top:8px;
  transition:all .2s; border:none;
}
.pcard__cta--pri { background:var(--teal-700); color:#fff; }
.pcard__cta--pri:hover { background:var(--teal-600); }
.pcard__cta--sec { background:transparent; color:var(--teal-700); border:1.5px solid var(--n200); }
.pcard__cta--sec:hover { border-color:var(--n300); }
.pcard__foot { text-align:center; font:400 12px/1.4 var(--font-b); color:var(--n500); margin-top:12px; }


/* ══════════ BOTTOM CTA ══════════ */
.bcta {
  padding:var(--section-pad) 40px; background:var(--teal-700);
  text-align:center; position:relative; overflow:hidden;
}
.bcta::before {
  content:''; position:absolute; top:-40%; left:50%; transform:translateX(-50%);
  width:100%; height:180%;
  background:radial-gradient(ellipse at center, rgba(110,207,171,.05) 0%, transparent 60%);
}
.bcta__in { position:relative; z-index:1; max-width:480px; margin:0 auto; }
.bcta__title {
  font-family:var(--font-h); font-weight:600;
  font-size:clamp(28px, 3.5vw, 44px); line-height:1.12;
  color:var(--mint); margin-bottom:14px;
}
.bcta__desc { font:400 15px/1.7 var(--font-b); color:rgba(255,255,255,.45); margin-bottom:32px; }
.bcta__btn {
  height:48px; padding:0 32px; border-radius:999px; border:none;
  background:var(--white); color:var(--teal-700);
  font:600 15px/1 var(--font-b);
  box-shadow:0 2px 12px rgba(0,0,0,.08);
  transition:all .25s;
}
.bcta__btn:hover { transform:translateY(-2px); box-shadow:0 4px 20px rgba(0,0,0,.14); }


/* ══════════ FOOTER ══════════ */
.foot { padding:40px; background:var(--teal-900); }
.foot__in {
  max-width:var(--max-w); margin:0 auto;
  display:flex; justify-content:space-between; align-items:center;
}
.foot__logo { display:flex; align-items:center; gap:8px; }
.foot__badge { width:26px; height:26px; background:var(--teal-700); border-radius:6px; display:grid; place-items:center; font:700 10px/1 var(--font-b); color:var(--mint-light); }
.foot__name { font:600 15px/1 var(--font-b); color:rgba(255,255,255,.6); }
.foot__links { display:flex; gap:28px; }
.foot__link { font:400 12px/1 var(--font-b); color:rgba(255,255,255,.35); transition:color .2s; }
.foot__link:hover { color:rgba(255,255,255,.6); }
.foot__copy { font:400 12px/1 var(--font-b); color:rgba(255,255,255,.2); }


/* ══════════ SCROLL REVEAL ══════════ */
.rv { opacity:0; transform:translateY(20px); transition:opacity .6s cubic-bezier(.16,1,.3,1), transform .6s cubic-bezier(.16,1,.3,1); }
.rv.vis { opacity:1; transform:translateY(0); }
.rv-d1 { transition-delay:.08s; }
.rv-d2 { transition-delay:.16s; }
.rv-d3 { transition-delay:.24s; }

/* ══════════ RESPONSIVE ══════════ */
@media(max-width:900px) {
  .hero__in, .feat__in, .why__grid, .pricing__cards { grid-template-columns:1fr; gap:40px; }
  .feat--rev .feat__in { direction:ltr; }
  .trust__in { grid-template-columns:1fr 1fr; gap:24px; }
  .nav__links { display:none; }
  .hero { min-height:auto; padding:110px 0 70px; }
  .hero__vis { order:-1; }
}
</style>
</head>
<body>

<!-- NAV -->
<nav class="nav nav--clear" id="nav">
  <div class="nav__in">
    <a class="nav__logo"><div class="nav__badge">AC</div><span class="nav__name">Autoceny</span></a>
    <div class="nav__links">
      <a class="nav__link" href="#how">Jak to działa</a>
